<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Accueil{% endblock %}</title>
        {{ encore_entry_link_tags('app') }}
    </head>
    <body>
        <header class="site-header">
            <nav class="nav">
                <a class="logo" href="{{ path('home') }}">LOGO</a>

                <button class="burger" type="button" aria-label="Ouvrir le menu" aria-expanded="false">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <ul class="nav-list">
                    <li><a href="{{ path('home') }}">Accueil</a></li>
                    <li><a href="{{ path('app_balade_index') }}">Balade</a></li>
                    <li><a href="{{ path('app_search') }}">Rechercher</a></li>

                    {% if is_granted('ROLE_USER') %}
                        <li>
                            <a href="{{ path('app_message_index') }}" class="nav-messages">
                                Messages
                                {% if unreadMessagesCount > 0 %}
                                    <span class="nav-messages__badge">{{ unreadMessagesCount }}</span>
                                {% endif %}
                            </a>
                        </li>
                        <li><a href="{{ path('profil') }}">Profil</a></li>
                        <li><a href="{{ path('logout') }}">Déconnexion</a></li>
                    {% else %}
                        <li><a href="{{ path('login') }}">Connexion</a></li>
                    {% endif %}
                </ul>
            </nav>
        </header>

        {% block body %}{% endblock %}

        {% block javascripts %}{% endblock %}

        {{ encore_entry_script_tags('app') }}

        <script>
            const header = document.querySelector('.site-header');
            const burger = document.querySelector('.burger');

            burger.addEventListener('click', () => {
                const isOpen = header.classList.toggle('open');
                burger.setAttribute('aria-expanded', String(isOpen));
            });
        </script>

        {% if is_granted('ROLE_USER') %}
            <script>
                async function refreshUnreadBadge() {
                    const res  = await fetch('{{ path("app_message_unread_count") }}');
                    const data = await res.json();
                    const count = data.count;

                    let badge = document.querySelector('.nav-messages__badge');
                    const navLink = document.querySelector('.nav-messages');

                    if (count > 0) {
                        if (!badge) {
                            badge = document.createElement('span');
                            badge.className = 'nav-messages__badge';
                            navLink.appendChild(badge);
                        }
                        badge.textContent = count;
                    } else {
                        if (badge) badge.remove();
                    }
                }

                const notifUrl = new URL('{{ mercure("user/" ~ app.user.id ~ "/notifications")|escape("js") }}');
                const notifSource = new EventSource(notifUrl);

                notifSource.onmessage = (event) => {
                    const data = JSON.parse(event.data);

                    // Vérifie si on est déjà sur la conversation concernée
                    const currentConvEl = document.getElementById('js-current-conversation');
                    if (currentConvEl) {
                        // On est sur une page de chat, on ignore la notif
                        // car les messages sont déjà marqués comme lus
                        return;
                    }

                    refreshUnreadBadge();
                };
            </script>
        {% endif %}
    </body>
</html>
