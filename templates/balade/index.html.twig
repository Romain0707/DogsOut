{% extends 'base.html.twig' %}

{% block title %}Balades{% endblock %}

{% block body %}
  <section id="balade">
    <div class="container">

        <div class="title-container">
            <h1 class="title">Balades</h1>
        </div>
        {% if is_granted('ROLE_USER') %}
            <a href="{{path ('app_balade_form')}}" class="create-balade create-balade--add">
                <span class="create-balade__add-icon">+</span>
                <span class="create-balade__add-label">Créer une balade</span>
            </a>
        {% endif %}

        <div class="balade-container">
            {{ include('partials/_balade_cards.html.twig') }}
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('.card-dropdown-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                e.preventDefault();

                document.querySelectorAll('.card-dropdown-menu.open').forEach(menu => {
                    if (menu !== btn.nextElementSibling) {
                        menu.classList.remove('open');
                    }
                });

                btn.nextElementSibling.classList.toggle('open');
            });
        });

        document.addEventListener('click', () => {
            document.querySelectorAll('.card-dropdown-menu.open').forEach(menu => {
                menu.classList.remove('open');
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.balade-card').forEach(card => {
                card.addEventListener('click', (e) => {
                    if (e.target.closest('a, button, form')) return;

                    const link = card.querySelector('a[href]');
                    if (link) window.location.href = link.href;
                });
            });
        });
    </script>
{% endblock %}