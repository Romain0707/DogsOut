<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Snapshot</title>
  <style>
    html, body { margin: 0; padding: 0; background: #f0ede8; }
    #map { width: 800px; height: 450px; }
  </style>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
</head>
<body>
  <div id="map"></div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>

    const raw = {{ balade.routeGeoJson is not empty ? balade.routeGeoJson | json_encode | raw : 'null' }};

    const map = L.map('map', {
      zoomControl: false,
      attributionControl: false,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
    }).addTo(map);

    function toFeatureCollection(data) {
      if (!data) return null;
      if (data.type === 'FeatureCollection') return data;
      if (data.type === 'Feature')           return { type: 'FeatureCollection', features: [data] };
      if (data.type === 'LineString' || data.type === 'MultiLineString') {
        return { type: 'FeatureCollection', features: [{ type: 'Feature', geometry: data, properties: {} }] };
      }
      if (Array.isArray(data) && data.length === 0) return null;
      return null;
    }

    let ready = false;

    function markReady() {
      if (!ready) { ready = true; window.__SNAPSHOT_READY__ = true; }
    }

    try {
      const geojson = toFeatureCollection(raw);

      if (geojson) {
        const layer = L.geoJSON(geojson, {
          style: () => ({
            color:    '#4a7c59',
            weight:   6,
            opacity:  0.95,
            lineCap:  'round',
            lineJoin: 'round',
          }),
        }).addTo(map);

        const bounds = layer.getBounds();
        if (bounds.isValid()) {
          map.fitBounds(bounds, { padding: [24, 24], maxZoom: 16 });
        } else {
          map.setView([46.2276, 2.2137], 6);
        }
      } else {
        map.setView([46.2276, 2.2137], 6);
      }
    } catch (e) {
      console.error('[snapshot] GeoJSON error:', e);
      map.setView([46.2276, 2.2137], 6);
    }

    let tilesLoaded = 0;
    map.on('tileloadend tileerror', () => {
      tilesLoaded++;
      if (tilesLoaded >= 4) markReady();
    });

    setTimeout(markReady, 8000);
  </script>
</body>
</html>
