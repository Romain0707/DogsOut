{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<section id="hero">
    <div class="container">
        <h1>Organisez et partagez des balades entre maîtres de chiens !</h1>

        <p>Trouvez et rejoignez des sorties canines près de chez vous avec d'autres passionnés de chiens.</p>

        <a href="{{ path ('app_balade_index') }}" class="btn">Explorer les Balades</a>

    </div>
</section>

<section id="balade">
    <div class="container">
        <h2>Dernière balade créer</h2>

        <div class="balade-container">
            {{ include('partials/_balade_cards.html.twig') }}
        </div>
    </div>
</section>

{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('.card-dropdown-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                e.preventDefault();

                // Ferme tous les autres
                document.querySelectorAll('.card-dropdown-menu.open').forEach(menu => {
                    if (menu !== btn.nextElementSibling) {
                        menu.classList.remove('open');
                    }
                });

                btn.nextElementSibling.classList.toggle('open');
            });
        });

        // Ferme au clic ailleurs
        document.addEventListener('click', () => {
            document.querySelectorAll('.card-dropdown-menu.open').forEach(menu => {
                menu.classList.remove('open');
            });
        });
    </script>
{% endblock %}