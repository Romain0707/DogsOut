{{ form_start(form, { attr: { class: 'chien-form', enctype: 'multipart/form-data' } }) }}

    <div class="chien-form__group">
        {{ form_label(form.name) }}
        {{ form_widget(form.name) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="chien-form__group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="chien-form__group">
        <span class="chien-form__group-label">{{ form_label(form.sexe) }}</span>
        <div class="chien-form__sexe">
            {% for child in form.sexe %}
                <div class="sexe-option">
                    {{ form_widget(child) }}
                    <label for="{{ child.vars.id }}">
                        <span class="sexe-option__symbol">
                            {{ child.vars.label starts with '♂' ? '♂' : '♀' }}
                        </span>
                        {{ child.vars.label starts with '♂' ? 'Mâle' : 'Femelle' }}
                    </label>
                </div>
            {% endfor %}
        </div>
        {{ form_errors(form.sexe) }}
    </div>

    <div class="chien-form__group">
        {{ form_label(form.birthDate) }}
        {{ form_widget(form.birthDate) }}
        {{ form_errors(form.birthDate) }}
    </div>

    <div class="chien-form__group">
        {{ form_label(form.race) }}
        {{ form_widget(form.race) }}
        {{ form_errors(form.race) }}
    </div>

    <div class="chien-form__group">
        <div class="profile-edit-avatar">
            {% if form.vars.data.imageName %}
                <img class="profile-edit-avatar__img"
                    src="{{ vich_uploader_asset(form.vars.data, 'imageFile') }}"
                    alt="Photo de {{ form.vars.data.name }}">
            {% else %}
                <img class="profile-edit-avatar__img"
                    src="{{ asset('uploads/images/default-dog.png') }}"
                    alt="Photo par défaut">
            {% endif %}
            <span class="profile-edit-avatar__label">Cliquez pour changer la photo</span>
        </div>
        {{ form_widget(form.imageFile) }}
        {{ form_errors(form.imageFile) }}
    </div>

    <div class="chien-form__actions">
        <button type="submit" class="chien-form__submit">Enregistrer</button>
    </div>

{{ form_end(form) }}
