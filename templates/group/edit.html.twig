{% extends 'base.html.twig' %}
{% block title %}Modifier · {{ group.name }}{% endblock %}
{% block body %}
<div class="chien-form-page">
    <h1 class="chien-form-page__title">{{ group.name }}</h1>
    <p class="chien-form-page__subtitle">Modifiez les informations du groupe.</p>
    <div class="chien-form-page__card">
        {{ form_start(form, { attr: { class: 'chien-form' } }) }}
            <div class="chien-form__group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>
            <div class="chien-form__group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>
            <div class="chien-form__group chien-form__group--checkbox">
                {{ form_widget(form.isPublic) }}
                {{ form_label(form.isPublic) }}
                {{ form_errors(form.isPublic) }}
            </div>
            <div class="chien-form__actions">
                <a href="{{ path('app_group_show', {'id': group.id}) }}" class="chien-form__back">← Retour</a>
                <button type="submit" class="chien-form__submit">Enregistrer</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
