{% extends 'base.html.twig' %}

{% block title %}Profil · {{ user.username }}{% endblock %}

{% block body %}
<section id="profile">
    <div class="container">

        <div class="profile-header">
            <img class="profile-avatar"
                src="{{ user.imageName ? vich_uploader_asset(user, 'imageFile') : asset('profil/default-avatar.png') }}"
                alt="Avatar de {{ user.username }}">

            <div class="profile-header-info">
                <h1 class="profile-username">{{ user.username }}</h1>
                <p class="profile-email">{{ user.email }}</p>
            </div>

            {% if currentUser %}
                <a href="{{ path('app_message_with', {'id': user.id}) }}"
                   class="profile-edit-btn">
                    Envoyer un message
                </a>
            {% endif %}
        </div>

        <div class="profile-body">

            <div class="profile-info-grid">
                <div class="profile-info-item">
                    <div class="profile-info-label">Prénom</div>
                    <div class="profile-info-value {% if not user.firstname %}empty{% endif %}">
                        {{ user.firstname ?? 'Non renseigné' }}
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="profile-info-label">Nom</div>
                    <div class="profile-info-value {% if not user.lastname %}empty{% endif %}">
                        {{ user.lastname ?? 'Non renseigné' }}
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="profile-info-label">Membre depuis</div>
                    <div class="profile-info-value">
                        {{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}
                    </div>
                </div>
                <div class="profile-info-item">
                    <div class="profile-info-label">Balades créées</div>
                    <div class="profile-info-value">{{ user.balades|length }}</div>
                </div>
                <div class="profile-info-item full">
                    <div class="profile-info-label">À propos</div>
                    <div class="profile-info-value {% if not user.description %}empty{% endif %}">
                        {{ user.description ?? 'Aucune description.' }}
                    </div>
                </div>
            </div>

            <div class="profile-divider">
                <p>Ses chiens</p>
            </div>

            <div class="chiens-grid">
                {% for chien in user.chiens %}
                <div class="chien-card">
                    <div class="chien-card__body">
                        <div class="chien-card__photo">
                            <img src="{{ chien.imageName == null 
                            ? asset('uploads/images/default-dog.png') 
                            : vich_uploader_asset(chien, 'imageFile') }}"
                            alt="Photo de {{ chien.name }}">
                        </div>
                        <h3 class="chien-card__name">{{ chien.name }}</h3>
                        <span class="chien-card__race">{{ chien.race.name }}</span>
                        <div class="chien-card__sexe chien-card__sexe--{{ chien.sexe ? 'male' : 'female' }}">
                            {{ chien.sexe ? '♂' : '♀' }}
                        </div>
                        {% if chien.birthDate %}
                        <p class="chien-card__meta">
                            Né{{ chien.sexe ? '' : 'e' }} le {{ chien.birthDate|date('d/m/Y') }}
                        </p>
                        {% endif %}
                        {% if chien.description %}
                        <p class="chien-card__desc">
                            {{ chien.description|length > 100
                                ? chien.description|slice(0, 100) ~ '…'
                                : chien.description }}
                        </p>
                        {% endif %}
                    </div>
                </div>
                {% else %}
                <div class="chiens-empty">
                    <p>Aucun chien enregistré.</p>
                </div>
                {% endfor %}
            </div>

            <div class="profile-divider">
                <p>Ses balades</p>
            </div>

            <div class="balade-container">
                {{ include('partials/_balade_cards.html.twig', {'balades': user.balades}) }}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.balade-card').forEach(card => {
                card.addEventListener('click', (e) => {
                    if (e.target.closest('a, button, form')) return;

                    const link = card.querySelector('a[href]');
                    if (link) window.location.href = link.href;
                });
            });
        });
    </script>
{% endblock %}