{% for balade in balades %}
<div class="balade-card">
    <a href="{{ path('app_balade_show', {'id': balade.id}) }}"></a>
    <div class="balade-card-img">
        {% set firstImage = balade.images.first %}
        {% if firstImage and firstImage.filename %}
            <img
                src="{{ vich_uploader_asset(firstImage, 'imageFile') }}"
                alt="{{ balade.title }}"
            >
        {% else %}
            <img
                src="{{ asset('uploads/images/default-balade.jpg') }}"
                alt="Image par défaut"
            >
        {% endif %}

        {% if balade.user %}
            <a href="{{ path('profil_public', {'id': balade.user.id}) }}" class="balade-card-author">
                {% if balade.user.imageName %}
                    <img
                        src="{{ vich_uploader_asset(balade.user, 'imageFile') }}"
                        alt="{{ balade.user.username  }}"
                        class="balade-card-author-avatar"
                    >
                {% else %}
                    <img
                        src="{{ asset('uploads/images/default-avatar.png') }}"
                        alt="{{ balade.user.username }}"
                        class="balade-card-author-avatar"
                    >
                {% endif %}
                <span class="balade-card-author-name">
                    <span>{{ balade.user.username }}</span>
                </span>
            </a>
        {% endif %}

        {% if app.user and balade.user and app.user == balade.user %}
            <div class="card-dropdown">
                <button class="card-dropdown-btn" type="button">
                    <svg width="24" height="24" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-width="3" d="M6 12h.01m6 0h.01m5.99 0h.01"/>
                    </svg>
                </button>
                <ul class="card-dropdown-menu">
                    <li><a href="{{ path('app_balade_form', {'id': balade.id}) }}">Modifier</a></li>
                    <li>{{ include('balade/_delete_form.html.twig') }}</li>
                </ul>
            </div>
        {% endif %}
    </div>

    <div class="balade-body">

        <div class="balade-title">
            <h2>
                <a href="{{ path('app_balade_show', {'id': balade.id}) }}">
                    {{ balade.title }}
                </a>
            </h2>
        </div>

        <div class="balade-desc">
            {% if balade.description %}
                <p>
                    {{ balade.description|length > 160
                        ? (balade.description|slice(0, 160) ~ '…')
                        : balade.description
                    }}
                </p>
            {% else %}
                <p><em>Aucune description.</em></p>
            {% endif %}
        </div>

        <ul>
            {% if balade.distanceMeters %}
                <li class="balade-meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="rgba(120, 130, 125, 1)" d="m10.9 15l-1.625 7.2q-.075.35-.363.575T8.25 23q-.5 0-.8-.375t-.2-.85L10.075 7.45q.15-.725.675-1.088T11.85 6t1.063.25t.787.75l1 1.6q.45.725 1.163 1.312t1.637.863V9.75q0-.325.213-.537T18.25 9t.538.213t.212.537v12.5q0 .325-.213.538T18.25 23t-.537-.213t-.213-.537v-9.4q-1.2-.275-2.225-.875T13.5 10.5l-.6 3l1.8 1.7q.15.15.225.338t.075.387V22q0 .425-.288.713T14 23t-.712-.288T13 22v-5zm-4.45-2.05l-1.15-.225q-.4-.075-.625-.413t-.15-.762l.75-3.925q.15-.85.9-1.287T7.8 6.075q.425.075.638.413t.137.762l-.95 4.9q-.075.425-.412.65t-.763.15m5.638-8.037Q11.5 4.325 11.5 3.5t.588-1.412T13.5 1.5t1.413.588T15.5 3.5t-.587 1.413T13.5 5.5t-1.412-.587"/></svg>
                    {% if balade.distanceMeters < 1000 %}
                        {{ balade.distanceMeters }} m
                    {% else %}
                        {{ (balade.distanceMeters / 1000)|number_format(2, ',', ' ') }} km
                    {% endif %}
                </li>
            {% endif %}

            {% if balade.durationSeconds %}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="rgba(120, 130, 125, 1)" d="M14.55 16.55L11 13V8h2v4.175l2.95 2.95zM11 6V4h2v2zm7 7v-2h2v2zm-7 7v-2h2v2zm-7-7v-2h2v2zm8 9q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22m0-2q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"/></svg>                {% set h = (balade.durationSeconds // 3600) %}
                {% set mins = ((balade.durationSeconds % 3600) // 60) %}
                <li class="balade-meta-item">
                    {% if h > 0 %}{{ h }} h {% endif %}{{ mins }} min
                </li>
            {% endif %}

            {% if balade.difficulty %}
                <li class="balade-meta-item">
                    <span class="badge badge--{{ balade.difficulty }}">
                        {{ balade.difficulty }}
                    </span>
                </li>
            {% endif %}
        </ul>

        {% if balade.baladeTags|length > 0 %}
            <div class="balade-tags">
                <ul>
                    {% set tags = balade.baladeTags %}
                    {% for tag in tags|slice(0, 4) %}
                        <li><a href="#">{{ tag.name }}</a></li>
                    {% endfor %}

                    {% if tags|length == 5 %}
                        <li class="balade-tags-meta">+{{ tags|length - 4 }} autre</li>
                    {% elseif tags|length > 5 %}
                        <li class="balade-tags-meta">+{{ tags|length - 4 }} autres</li>
                    {% endif %}
                </ul>
            </div>
        {% endif %}
    </div>

    <div class="balade-footer">
        <ul>
            <li class="balade-date">
                {% if balade.createdAt is defined and balade.createdAt %}
                    {% set diff = date() | date('U') - balade.createdAt|date('U') %}
                    {% set days = (diff / 86400)|round(0, 'floor') %}

                    {% if days == 0 %}
                        Aujourd'hui
                    {% elseif days == 1 %}
                        Il y a 1 jour
                    {% else %}
                        Il y a {{ days }} jours
                    {% endif %}
                {% endif %}
            </li>
            <li class="balade-comments">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path d="M115.9 448.9C83.3 408.6 64 358.4 64 304C64 171.5 178.6 64 320 64C461.4 64 576 171.5 576 304C576 436.5 461.4 544 320 544C283.5 544 248.8 536.8 217.4 524L101 573.9C97.3 575.5 93.5 576 89.5 576C75.4 576 64 564.6 64 550.5C64 546.2 65.1 542 67.1 538.3L115.9 448.9zM153.2 418.7C165.4 433.8 167.3 454.8 158 471.9L140 505L198.5 479.9C210.3 474.8 223.7 474.7 235.6 479.6C261.3 490.1 289.8 496 319.9 496C437.7 496 527.9 407.2 527.9 304C527.9 200.8 437.8 112 320 112C202.2 112 112 200.8 112 304C112 346.8 127.1 386.4 153.2 418.7z"/></svg>
                </span>
                <span>{{ balade.comments|length }}</span>
            </li>
            <li class="balade-rating">
                {% if balade.baladeRatings is defined and balade.baladeRatings|length > 0 %}
                    {% set total = 0 %}
                    {% for rating in balade.baladeRatings %}
                        {% set total = total + rating.rating %}
                    {% endfor %}
                    {% set avg = balade.baladeRatings|reduce((carry, r) => carry + r.rating, 0) %}
                    {% set avg = balade.baladeRatings|length > 0 ? (avg / balade.baladeRatings|length) : 0 %}
                    {% set avgDisplay = ((avg * 10)|round(0, 'floor') / 10) %}
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="m7.625 6.4l2.8-3.625q.3-.4.713-.587T12 2t.863.188t.712.587l2.8 3.625l4.25 1.425q.65.2 1.025.738t.375 1.187q0 .3-.088.6t-.287.575l-2.75 3.9l.1 4.1q.025.875-.575 1.475t-1.4.6q-.05 0-.55-.075L12 19.675l-4.475 1.25q-.125.05-.275.063T6.975 21q-.8 0-1.4-.6T5 18.925l.1-4.125l-2.725-3.875q-.2-.275-.288-.575T2 9.75q0-.625.363-1.162t1.012-.763zM8.85 8.125L4 9.725L7.1 14.2L7 18.975l5-1.375l5 1.4l-.1-4.8L20 9.775l-4.85-1.65L12 4zM12 11.5"/></svg>
                    </span>
                    <span class="balade-rating__value">
                        {{ avgDisplay|number_format(1, ',')|replace({',0': ''}) }}
                    </span>
                {% else %}
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="currentColor" d="m7.625 6.4l2.8-3.625q.3-.4.713-.587T12 2t.863.188t.712.587l2.8 3.625l4.25 1.425q.65.2 1.025.738t.375 1.187q0 .3-.088.6t-.287.575l-2.75 3.9l.1 4.1q.025.875-.575 1.475t-1.4.6q-.05 0-.55-.075L12 19.675l-4.475 1.25q-.125.05-.275.063T6.975 21q-.8 0-1.4-.6T5 18.925l.1-4.125l-2.725-3.875q-.2-.275-.288-.575T2 9.75q0-.625.363-1.162t1.012-.763zM8.85 8.125L4 9.725L7.1 14.2L7 18.975l5-1.375l5 1.4l-.1-4.8L20 9.775l-4.85-1.65L12 4zM12 11.5"/></svg>
                    </span>
                    <span class="balade-rating__empty">–</span>
                {% endif %}
            </li>
        </ul>
    </div>
</div>
{% else %}
<div class="balade-card">
    <div class="balade-body">
        <p>Aucune balade pour l'instant.</p>
    </div>
</div>
{% endfor %}